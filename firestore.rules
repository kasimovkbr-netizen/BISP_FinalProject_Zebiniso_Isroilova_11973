rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vaccination Records - parents can only access their own children's records
    match /vaccination_records/{recordId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.parentId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.parentId;
    }

    // User Payment Profiles - users can only access their own profile
    match /user_payment_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Transactions - users can read their own transactions, system can create
    match /transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null &&
        (request.auth.token.admin == true ||
         (request.auth.uid == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt'])));
    }

    // Usage Records - users can read their own usage, system can create
    match /usage_records/{usageId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Credit Packages - read-only for authenticated users, admin can modify
    match /credit_packages/{packageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Subscription Tiers - read-only for authenticated users, admin can modify
    match /subscription_tiers/{tierId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Free Usage Tracking - users can access their own tracking data
    match /free_usage_tracking/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Analysis Cache - system managed, users can read cached results
    match /analysis_cache/{cacheKey} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // System Configuration - read-only for authenticated users, admin can modify
    match /system_config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Audit Logs - admin only access
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
